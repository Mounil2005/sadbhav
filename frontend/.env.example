# ─────────────────────────────────────────────
# Sadbhav Hospital — Frontend Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# Cal.com booking link (namespace/event-slug)
VITE_CALCOM_LINK=mounil-kankhara-tsigot/30min

# WhatsApp number in international format (no + or spaces)
VITE_WHATSAPP_NUMBER=919725232641

# Hospital phone in E.164 format
VITE_HOSPITAL_PHONE=+919725232641

# Contact email
VITE_CONTACT_EMAIL=info@sadbhavhospital.in

# Google Maps embed URL (full iframe src value)
VITE_GOOGLE_MAPS_EMBED_URL=

# Site base URL (used for SEO/og tags when added)
VITE_SITE_URL=https://sadbhavhospital.in

# Sanity CMS (public — safe to expose in frontend)
VITE_SANITY_PROJECT_ID=v0ztl8cn
VITE_SANITY_DATASET=production

# Sanity write token — used only for patient review submissions
# Create at manage.sanity.io → API → Tokens → Add API token (Editor role)
VITE_SANITY_WRITE_TOKEN=
