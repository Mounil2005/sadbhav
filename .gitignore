# ─────────────────────────────────────────────
# Sadbhav Hospital — Root .gitignore
# ─────────────────────────────────────────────

# AI tooling
.claude/
.gemini/

# Frontend — dependencies and build output
frontend/node_modules/
frontend/.vite/

# Sanity Studio — dependencies and build output
studio-sadbhav-hospital/node_modules/
studio-sadbhav-hospital/dist/
frontend/dist/
frontend/.pnp
frontend/.pnp.js
frontend/.vite/

# Environment files (never commit real secrets)
.env
.env.local
.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.*.local

# Credentials and sensitive files (keep folder, ignore contents)
credentials/*
!credentials/.gitkeep

# Backups (keep folder, ignore contents)
backups/*
!backups/.gitkeep

# Editor / OS artifacts
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.suo
*.user

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
*.zip
*.tar.gz

.vercel
.env*
